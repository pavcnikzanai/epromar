---
import Layout from '../layouts/Layout.astro';

const storitve = [
  { id: 'servis', naziv: 'Servis računalniške opreme', kratko: 'Diagnostika, popravilo, garancija.', stat: 'od 1993' },
  { id: 'outsourcing', naziv: 'Outsourcing IT', kratko: 'Vaš zunanji IT oddelek.', stat: '20+ let' },
  { id: 'prodaja', naziv: 'Prodaja opreme', kratko: 'Računalniki, oprema, elektronika.', stat: '8–16h' },
  { id: 'vzdrzevanje', naziv: 'Pogodbeno vzdrževanje', kratko: 'Preventiva pred izpadom.', stat: '4 h' },
  { id: 'omrezje', naziv: 'Omrežna infrastruktura', kratko: 'Projekt, ožičenje, meritve.', stat: 'Cat 6 / OS2' },
  { id: 'spletne', naziv: 'Spletne storitve', kratko: 'Spletne strani in optimizacija.', stat: 'celostno' },
  { id: 'oddaljena', naziv: 'Oddaljena pomoč', kratko: 'Težava rešena brez obiska.', stat: '7–15 h' },
  { id: 'os', naziv: 'Sistemi in OS', kratko: 'OS, gonilniki, namestitev.', stat: 'na lokaciji' },
];
---

<Layout title="Demo: Storitve">
  <style>
    .demo-section { min-height: 100vh; padding: 80px 24px; position: relative; }
    .demo-label {
      position: sticky; top: 16px; z-index: 50;
      display: inline-flex; align-items: center; gap: 10px;
      padding: 8px 14px; border-radius: 999px;
      background: #0A0F1E; color: white;
      font-family: 'JetBrains Mono', monospace; font-size: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
    .demo-label span:first-child { color: #89B4FF; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    .serif-it { font-family: 'Instrument Serif', serif; font-style: italic; }
  </style>

  <main style="background: #0A0F1E; color: white; font-family: 'Nunito', sans-serif;">

    <!-- ================ VARIANT 1 — HORIZONTAL SCROLL CARDS ================ -->
    <section class="demo-section" style="background: #0A0F1E;">
      <div class="demo-label"><span>01</span><span>Horizontal scroll cards (cinematic)</span></div>

      <div style="overflow-x: auto; scroll-snap-type: x mandatory; padding: 60px 0; margin-top: 40px;">
        <div style="display: flex; gap: 24px; padding: 0 8vw;">
          {storitve.map((s, i) => (
            <article style="flex: 0 0 70vw; min-width: 600px; max-width: 920px; aspect-ratio: 16/10; scroll-snap-align: center; border-radius: 24px; padding: 48px; position: relative; overflow: hidden; background: linear-gradient(135deg, #111a30 0%, #0A0F1E 100%); border: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; justify-content: space-between;">
              <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 48px 48px; pointer-events: none;"></div>
              <div style="position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(77,142,255,0.18), transparent 70%); pointer-events: none;"></div>

              <div style="position: relative; display: flex; justify-content: space-between; align-items: flex-start;">
                <div class="mono" style="font-size: 11px; letter-spacing: 0.2em; color: #89B4FF; text-transform: uppercase;">
                  {String(i+1).padStart(2,'0')} / {String(storitve.length).padStart(2,'0')}
                </div>
                <div class="mono" style="font-size: 11px; color: rgba(255,255,255,0.4);">→ scroll</div>
              </div>

              <div style="position: relative;">
                <h3 style="font-size: clamp(2rem, 4vw, 3.6rem); font-weight: 900; letter-spacing: -0.03em; line-height: 1; margin-bottom: 16px;">
                  {s.naziv}
                </h3>
                <p style="color: rgba(255,255,255,0.55); max-width: 50ch; font-size: 15px; line-height: 1.7;">
                  {s.kratko} Servis na lokaciji, hiter odzivni čas, garancija na opravljeno delo.
                </p>
              </div>

              <div style="position: relative; display: flex; justify-content: space-between; align-items: flex-end;">
                <div>
                  <div style="font-size: 2rem; font-weight: 700;">{s.stat}</div>
                  <div class="mono" style="font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-top: 4px;">aktivno</div>
                </div>
                <div class="mono" style="font-size: 11px; color: rgba(255,255,255,0.3);">epromar.si/{s.id}</div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ================ VARIANT 2 — BENTO GRID ================ -->
    <section class="demo-section" style="background: #fafaf9; color: #0A0F1E;">
      <div class="demo-label"><span>02</span><span>Bento grid (moderno, asimetrično)</span></div>

      <div style="max-width: 1280px; margin: 60px auto 0;">
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 200px; gap: 16px;">

          <div style="grid-column: span 2; grid-row: span 2; background: linear-gradient(135deg, #0A0F1E 0%, #1B3C8F 100%); color: white; border-radius: 24px; padding: 32px; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden;">
            <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"></div>
            <div class="mono" style="position: relative; font-size: 11px; letter-spacing: 0.2em; color: #89B4FF;">01 — FLAGSHIP</div>
            <div style="position: relative;">
              <h3 style="font-size: 2.4rem; font-weight: 900; letter-spacing: -0.03em; line-height: 1;">Servis<br/>računalniške<br/>opreme</h3>
              <p style="color: rgba(255,255,255,0.6); margin-top: 16px; font-size: 14px; max-width: 32ch;">Diagnostika, popravilo na lokaciji, garancija. Od 1993.</p>
            </div>
          </div>

          <div style="grid-column: span 2; background: white; border: 1px solid rgba(10,15,30,0.08); border-radius: 24px; padding: 28px; display: flex; flex-direction: column; justify-content: space-between;">
            <div class="mono" style="font-size: 10px; letter-spacing: 0.2em; color: rgba(10,15,30,0.4);">02</div>
            <div>
              <h3 style="font-size: 1.4rem; font-weight: 800; letter-spacing: -0.02em;">Outsourcing IT</h3>
              <p style="color: rgba(10,15,30,0.55); font-size: 13px; margin-top: 6px;">Vaš zunanji IT oddelek.</p>
            </div>
          </div>

          <div style="background: #0A0F1E; color: white; border-radius: 24px; padding: 24px; display: flex; flex-direction: column; justify-content: space-between;">
            <div class="mono" style="font-size: 10px; letter-spacing: 0.2em; color: #89B4FF;">03</div>
            <div>
              <div style="font-size: 1.8rem; font-weight: 900;">4h</div>
              <div style="font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px;">odzivni čas v paketu</div>
              <div style="font-size: 14px; font-weight: 600; margin-top: 12px;">Pogodbeno vzdrževanje</div>
            </div>
          </div>

          <div style="background: white; border: 1px solid rgba(10,15,30,0.08); border-radius: 24px; padding: 24px;">
            <div class="mono" style="font-size: 10px; letter-spacing: 0.2em; color: rgba(10,15,30,0.4);">04</div>
            <h3 style="font-size: 1.2rem; font-weight: 800; margin-top: 20px;">Prodaja opreme</h3>
            <p style="color: rgba(10,15,30,0.5); font-size: 12px; margin-top: 4px;">Računalniki, periferija, elektronika.</p>
          </div>

          <div style="grid-column: span 2; background: linear-gradient(135deg, #4D8EFF 0%, #1B3C8F 100%); color: white; border-radius: 24px; padding: 32px; display: flex; flex-direction: column; justify-content: space-between;">
            <div class="mono" style="font-size: 11px; letter-spacing: 0.2em; color: rgba(255,255,255,0.7);">05 — INFRASTRUKTURA</div>
            <div>
              <h3 style="font-size: 1.8rem; font-weight: 900; letter-spacing: -0.02em; line-height: 1.1;">Omrežna<br/>infrastruktura</h3>
              <p style="color: rgba(255,255,255,0.85); font-size: 13px; margin-top: 12px;">Projektiranje · ožičenje · meritve s certifikatom</p>
            </div>
          </div>

          <div style="background: white; border: 1px solid rgba(10,15,30,0.08); border-radius: 24px; padding: 24px;">
            <div class="mono" style="font-size: 10px; letter-spacing: 0.2em; color: rgba(10,15,30,0.4);">06</div>
            <h3 style="font-size: 1.2rem; font-weight: 800; margin-top: 20px;">Spletne storitve</h3>
            <p style="color: rgba(10,15,30,0.5); font-size: 12px; margin-top: 4px;">Strani, SEO, oblikovanje.</p>
          </div>

          <div style="background: white; border: 1px solid rgba(10,15,30,0.08); border-radius: 24px; padding: 24px;">
            <div class="mono" style="font-size: 10px; letter-spacing: 0.2em; color: rgba(10,15,30,0.4);">07</div>
            <h3 style="font-size: 1.2rem; font-weight: 800; margin-top: 20px;">Oddaljena pomoč</h3>
            <p style="color: rgba(10,15,30,0.5); font-size: 12px; margin-top: 4px;">Brez obiska, takoj.</p>
          </div>

          <div style="background: white; border: 1px solid rgba(10,15,30,0.08); border-radius: 24px; padding: 24px;">
            <div class="mono" style="font-size: 10px; letter-spacing: 0.2em; color: rgba(10,15,30,0.4);">08</div>
            <h3 style="font-size: 1.2rem; font-weight: 800; margin-top: 20px;">OS in gonilniki</h3>
            <p style="color: rgba(10,15,30,0.5); font-size: 12px; margin-top: 4px;">Namestitev, migracija.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ================ VARIANT 3 — STICKY PIN STORY ================ -->
    <section class="demo-section" style="background: #0A0F1E;">
      <div class="demo-label"><span>03</span><span>Sticky-pin scroll story</span></div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; max-width: 1280px; margin: 60px auto 0;">
        <div style="position: sticky; top: 100px; height: 70vh; border-radius: 24px; background: linear-gradient(135deg, #111a30 0%, #0A0F1E 100%); border: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;">
          <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"></div>

          <svg viewBox="0 0 300 300" style="width: 70%; max-width: 360px; position: relative; z-index: 2;">
            <rect x="40" y="60" width="220" height="180" rx="6" stroke="rgba(255,255,255,0.4)" stroke-width="1" fill="none"/>
            <line x1="40" y1="100" x2="260" y2="100" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
            <line x1="40" y1="140" x2="260" y2="140" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
            <line x1="40" y1="180" x2="260" y2="180" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
            <circle cx="60" cy="80" r="2" fill="#4D8EFF"/>
            <circle cx="60" cy="120" r="2" fill="#4D8EFF"/>
            <circle cx="60" cy="160" r="2" fill="rgba(255,255,255,0.4)"/>
            <circle cx="60" cy="200" r="2" fill="#4D8EFF"/>
            <text x="150" y="270" text-anchor="middle" fill="#89B4FF" font-family="JetBrains Mono" font-size="10" letter-spacing="2">SERVER · CELJE · DC1</text>
          </svg>
        </div>

        <div style="display: flex; flex-direction: column; gap: 100px;">
          {storitve.slice(0,4).map((s, i) => (
            <div style="min-height: 60vh; display: flex; flex-direction: column; justify-content: center;">
              <div class="mono" style="font-size: 11px; letter-spacing: 0.2em; color: #89B4FF; margin-bottom: 16px;">
                ETAPA {String(i+1).padStart(2,'0')}
              </div>
              <h3 style="font-size: 2.4rem; font-weight: 900; letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 20px;">{s.naziv}</h3>
              <p style="color: rgba(255,255,255,0.55); font-size: 15px; line-height: 1.7; max-width: 42ch;">
                {s.kratko} Med scrollom se ozadje (server, kabli, omrežje) animira in razkriva del sistema, ki ga ta storitev pokriva.
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================ VARIANT 4 — TERMINAL ================ -->
    <section class="demo-section" style="background: #050810;">
      <div class="demo-label"><span>04</span><span>Terminal / komandna vrstica</span></div>

      <div style="max-width: 1100px; margin: 60px auto 0; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); overflow: hidden; box-shadow: 0 40px 80px rgba(0,0,0,0.5);">
        <div style="background: #0d1220; padding: 12px 16px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid rgba(255,255,255,0.06);">
          <span style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f56;"></span>
          <span style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e;"></span>
          <span style="width: 12px; height: 12px; border-radius: 50%; background: #27c93f;"></span>
          <span class="mono" style="margin-left: 16px; font-size: 12px; color: rgba(255,255,255,0.5);">~ epromar — zsh</span>
        </div>
        <div class="mono" style="background: #050810; padding: 32px; font-size: 14px; line-height: 1.9; color: rgba(255,255,255,0.85);">
          <div><span style="color: #89B4FF;">epromar@celje</span><span style="color: #6b7280;">:~$</span> ls storitve/</div>
          <div style="color: rgba(255,255,255,0.7); margin-left: 16px; margin: 8px 0 16px 16px; columns: 4; column-gap: 24px;">
            {storitve.map(s => <div>{s.id}/</div>)}
          </div>

          <div><span style="color: #89B4FF;">epromar@celje</span><span style="color: #6b7280;">:~$</span> cat storitve/servis.md</div>
          <div style="margin: 12px 0 24px 0; padding: 16px; background: rgba(77,142,255,0.05); border-left: 2px solid #4D8EFF; color: rgba(255,255,255,0.85);">
            <div style="color: white; font-weight: 700; margin-bottom: 8px;"># Servis računalniške opreme</div>
            <div style="color: rgba(255,255,255,0.7);">Diagnostika, popravilo, garancija. Servis na lokaciji stranke.</div>
            <div style="color: #6b7280; margin-top: 12px; font-size: 12px;">--&nbsp;hiter odzivni čas</div>
            <div style="color: #6b7280; font-size: 12px;">--&nbsp;garancija na opravljeno delo</div>
            <div style="color: #6b7280; font-size: 12px;">--&nbsp;diagnostika strojne in programske opreme</div>
          </div>

          <div><span style="color: #89B4FF;">epromar@celje</span><span style="color: #6b7280;">:~$</span> ./call --priority high</div>
          <div style="margin: 12px 0; color: #27c93f;">→ vzpostavljam povezavo na 03 490 11 90 ...</div>

          <div><span style="color: #89B4FF;">epromar@celje</span><span style="color: #6b7280;">:~$</span> <span style="background: rgba(255,255,255,0.85); width: 8px; height: 18px; display: inline-block; vertical-align: middle; animation: blink 1s infinite;"></span></div>
        </div>
      </div>
      <p style="text-align: center; color: rgba(255,255,255,0.4); margin-top: 24px; font-size: 13px;" class="mono">→ klik na storitev levo bi izpisal nov "cat &lt;ime&gt;.md" output</p>
      <style>@keyframes blink { 50% { opacity: 0; } }</style>
    </section>

    <!-- ================ VARIANT 5 — REAL PHOTO SPLIT ================ -->
    <section class="demo-section" style="background: #0A0F1E;">
      <div class="demo-label"><span>05</span><span>Real-photo split-screen</span></div>

      <div style="max-width: 1400px; margin: 60px auto 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 24px; overflow: hidden; min-height: 70vh; border: 1px solid rgba(255,255,255,0.08);">
        <div style="position: relative; min-height: 600px; overflow: hidden;">
          <img src="https://images.unsplash.com/photo-1591808216268-ce0b82787efe?q=85&w=1400&auto=format&fit=crop" alt="" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.4) contrast(1.1) brightness(0.6);"/>
          <div style="position: absolute; inset: 0; background: linear-gradient(135deg, rgba(27,60,143,0.4), transparent 60%); mix-blend-mode: overlay;"></div>
          <div style="position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(10,15,30,0.85));"></div>
          <div style="position: absolute; left: 24px; right: 24px; bottom: 24px; display: flex; justify-content: space-between;" class="mono">
            <span style="color: rgba(255,255,255,0.7); font-size: 12px;">arhiv · servis 2024</span>
            <span style="color: rgba(255,255,255,0.5); font-size: 12px;">FOTO 03/12</span>
          </div>
        </div>
        <div style="padding: 60px; background: #0A0F1E; display: flex; flex-direction: column; justify-content: center;">
          <div class="mono" style="font-size: 11px; letter-spacing: 0.2em; color: #89B4FF; margin-bottom: 20px;">STORITEV 01 / 08</div>
          <h3 style="font-size: 3rem; font-weight: 900; letter-spacing: -0.03em; line-height: 1; margin-bottom: 24px;">Servis<br/>računalniške<br/>opreme</h3>
          <p style="color: rgba(255,255,255,0.6); font-size: 16px; line-height: 1.7; max-width: 42ch; margin-bottom: 32px;">
            Servisiramo strojno in programsko računalniško opremo. Posege izvajamo večinoma na lokaciji stranke.
          </p>
          <div style="display: flex; flex-direction: column; gap: 4px;">
            {storitve.map((s, i) => (
              <button style={`text-align: left; padding: 12px 0; font-size: 14px; font-weight: ${i===0?'700':'400'}; color: ${i===0?'white':'rgba(255,255,255,0.4)'}; background: none; border: none; border-bottom: 1px solid rgba(255,255,255,0.06); cursor: pointer; display: flex; justify-content: space-between;`}>
                <span>{s.naziv}</span>
                <span class="mono" style="font-size: 11px; opacity: 0.6;">{String(i+1).padStart(2,'0')}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
      <p style="text-align: center; color: rgba(255,255,255,0.4); margin-top: 24px; font-size: 13px;">→ hover na storitev = leva fotka se cross-fada v drugo realno fotko</p>
    </section>

    <!-- ================ VARIANT 6 — INFRASTRUCTURE DIAGRAM ================ -->
    <section class="demo-section" style="background: #fafaf9; color: #0A0F1E;">
      <div class="demo-label"><span>06</span><span>Infrastruktura — interaktivni diagram</span></div>

      <div style="max-width: 1280px; margin: 60px auto 0; background: white; border-radius: 24px; padding: 60px; border: 1px solid rgba(10,15,30,0.08); position: relative;">
        <svg viewBox="0 0 1000 500" style="width: 100%; height: auto;">
          <defs>
            <pattern id="grid6" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(10,15,30,0.05)" stroke-width="1"/>
            </pattern>
          </defs>
          <rect width="1000" height="500" fill="url(#grid6)"/>

          <line x1="500" y1="80" x2="500" y2="250" stroke="#1B3C8F" stroke-width="1.5" stroke-dasharray="4 4"/>
          <line x1="200" y1="380" x2="500" y2="250" stroke="#1B3C8F" stroke-width="1.5"/>
          <line x1="500" y1="380" x2="500" y2="250" stroke="#1B3C8F" stroke-width="1.5"/>
          <line x1="800" y1="380" x2="500" y2="250" stroke="#1B3C8F" stroke-width="1.5"/>
          <line x1="350" y1="380" x2="350" y2="450" stroke="rgba(10,15,30,0.3)" stroke-width="1"/>
          <line x1="650" y1="380" x2="650" y2="450" stroke="rgba(10,15,30,0.3)" stroke-width="1"/>

          <g transform="translate(440 30)">
            <rect width="120" height="50" rx="8" fill="white" stroke="#1B3C8F" stroke-width="1.5"/>
            <text x="60" y="22" text-anchor="middle" fill="#0A0F1E" font-size="11" font-weight="700">OBLAK / WAN</text>
            <text x="60" y="38" text-anchor="middle" fill="#89B4FF" font-size="9" font-family="JetBrains Mono">→ spletne storitve</text>
          </g>

          <g transform="translate(450 230)">
            <rect width="100" height="40" rx="6" fill="#0A0F1E"/>
            <text x="50" y="18" text-anchor="middle" fill="white" font-size="10" font-weight="700">SWITCH / GW</text>
            <text x="50" y="32" text-anchor="middle" fill="#89B4FF" font-size="8" font-family="JetBrains Mono">→ omrežje</text>
          </g>

          <g transform="translate(150 360)">
            <rect width="100" height="60" rx="6" fill="white" stroke="rgba(10,15,30,0.4)" stroke-width="1.5"/>
            <text x="50" y="22" text-anchor="middle" fill="#0A0F1E" font-size="10" font-weight="700">STREŽNIK</text>
            <text x="50" y="38" text-anchor="middle" fill="#89B4FF" font-size="8" font-family="JetBrains Mono">→ vzdrževanje</text>
            <text x="50" y="50" text-anchor="middle" fill="rgba(10,15,30,0.5)" font-size="8" font-family="JetBrains Mono">4h SLA</text>
          </g>

          <g transform="translate(450 360)">
            <rect width="100" height="60" rx="6" fill="white" stroke="rgba(10,15,30,0.4)" stroke-width="1.5"/>
            <text x="50" y="22" text-anchor="middle" fill="#0A0F1E" font-size="10" font-weight="700">PRINTER</text>
            <text x="50" y="38" text-anchor="middle" fill="#89B4FF" font-size="8" font-family="JetBrains Mono">→ servis</text>
          </g>

          <g transform="translate(750 360)">
            <rect width="100" height="60" rx="6" fill="white" stroke="rgba(10,15,30,0.4)" stroke-width="1.5"/>
            <text x="50" y="22" text-anchor="middle" fill="#0A0F1E" font-size="10" font-weight="700">PC / WORKSTATION</text>
            <text x="50" y="38" text-anchor="middle" fill="#89B4FF" font-size="8" font-family="JetBrains Mono">→ outsourcing</text>
            <text x="50" y="50" text-anchor="middle" fill="rgba(10,15,30,0.5)" font-size="8" font-family="JetBrains Mono">oddaljena pomoč</text>
          </g>

          <g transform="translate(310 440)">
            <text x="40" y="0" text-anchor="middle" fill="rgba(10,15,30,0.5)" font-size="9" font-family="JetBrains Mono">staff</text>
          </g>
          <g transform="translate(610 440)">
            <text x="40" y="0" text-anchor="middle" fill="rgba(10,15,30,0.5)" font-size="9" font-family="JetBrains Mono">staff</text>
          </g>
        </svg>
        <p style="text-align: center; color: rgba(10,15,30,0.5); margin-top: 20px; font-size: 13px;">→ hover element = ustrezna storitev se osvetli, ostale zbledijo + side panel z detajli</p>
      </div>
    </section>

    <!-- ================ VARIANT 7 — MASSIVE TYPE WALL ================ -->
    <section class="demo-section" style="background: #0A0F1E; padding: 80px 0;">
      <div class="demo-label" style="margin-left: 24px;"><span>07</span><span>Massive type wall (brutalist)</span></div>

      <div style="max-width: 1500px; margin: 60px auto 0; padding: 0 40px;">
        {storitve.map((s, i) => (
          <div style="display: flex; align-items: baseline; gap: 24px; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.08);">
            <span class="mono" style="font-size: 12px; color: rgba(255,255,255,0.3); width: 40px;">{String(i+1).padStart(2,'0')}</span>
            <h3 style={`font-size: clamp(2.5rem, 6vw, 5.5rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1; flex: 1; ${i===2?'background: linear-gradient(95deg, white 0%, #4D8EFF 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;':'color: rgba(255,255,255,0.2);'}`}>
              {s.naziv}
            </h3>
            <span class="mono" style="font-size: 12px; color: rgba(255,255,255,0.4); white-space: nowrap;">{s.stat}</span>
          </div>
        ))}
      </div>
      <p style="text-align: center; color: rgba(255,255,255,0.4); margin-top: 40px; font-size: 13px;">→ hover na vrstico = obarva se v gradient, ostale zbledijo, side panel zdrsne z detajli</p>
    </section>

    <div style="text-align: center; padding: 60px; background: #0A0F1E; color: rgba(255,255,255,0.5);" class="mono">
      konec — povej kateri ti je najbolj všeč
    </div>

  </main>
</Layout>
