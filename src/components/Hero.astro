---
const now = new Date();
const day = now.getDay();
const hour = now.getHours();
const isOpen = day >= 1 && day <= 5 && hour >= 8 && hour < 16;

const photoUrl = 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?q=85&w=1400&auto=format&fit=crop';
---

<style>
  .serif-it { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; }

  .hero-bg {
    background:
      radial-gradient(ellipse 60% 50% at 0% 0%, rgba(77, 142, 255, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 100% 100%, rgba(27, 60, 143, 0.20) 0%, transparent 55%),
      #0A0F1E;
  }
  .hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.55'/></svg>");
    opacity: 0.04;
    pointer-events: none;
    mix-blend-mode: overlay;
    z-index: 1;
  }

  /* Photo frame — the showpiece */
  .photo-frame {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    isolation: isolate;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.05),
      0 40px 80px -30px rgba(0,0,0,0.6),
      0 20px 40px -20px rgba(27,60,143,0.4);
  }
  .photo-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(0.55) contrast(1.08) brightness(0.55);
    animation: ken-burns 38s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes ken-burns {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.12) translate(-2%, 2%); }
  }
  .photo-tint {
    position: absolute; inset: 0;
    background: #0A0F1E;
    mix-blend-mode: multiply;
    opacity: 0.55;
    z-index: 2;
  }
  .photo-color {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(27,60,143,0.45) 0%, rgba(77,142,255,0.20) 60%, transparent 100%);
    mix-blend-mode: screen;
    opacity: 0.7;
    z-index: 3;
  }
  .photo-fade {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, transparent 30%, rgba(10,15,30,0.55) 90%, rgba(10,15,30,0.85) 100%),
      radial-gradient(circle at 30% 25%, transparent 50%, rgba(10,15,30,0.4) 100%);
    z-index: 4;
  }
  .photo-corner-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    z-index: 5;
    mix-blend-mode: overlay;
  }
  .photo-content { position: absolute; inset: 0; z-index: 10; }

  /* corners (architectural marks on photo) */
  .corner {
    position: absolute;
    width: 14px; height: 14px;
    border-color: rgba(255,255,255,0.55);
  }
  .corner-tl { top: 14px; left: 14px; border-top: 1px solid; border-left: 1px solid; }
  .corner-tr { top: 14px; right: 14px; border-top: 1px solid; border-right: 1px solid; }
  .corner-bl { bottom: 14px; left: 14px; border-bottom: 1px solid; border-left: 1px solid; }
  .corner-br { bottom: 14px; right: 14px; border-bottom: 1px solid; border-right: 1px solid; }

  .photo-caption {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 26px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(13px, 1.55vw, 20px);
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.65);
    white-space: nowrap;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* mask reveal */
  .reveal-line { overflow: hidden; display: block; }
  .reveal-line > .reveal-inner {
    display: inline-block;
    transform: translateY(108%);
    animation: line-up 1.15s cubic-bezier(0.32, 0.72, 0, 1) forwards;
  }
  .l1 > .reveal-inner { animation-delay: 0.18s; }
  .l2 > .reveal-inner { animation-delay: 0.30s; }
  .l3 > .reveal-inner { animation-delay: 0.42s; }
  @keyframes line-up { to { transform: translateY(0); } }

  .fade-up {
    opacity: 0;
    transform: translateY(14px);
    animation: fade-up 1.05s cubic-bezier(0.32, 0.72, 0, 1) forwards;
  }
  @keyframes fade-up { to { opacity: 1; transform: translateY(0); } }

  /* gentle photo entry */
  .photo-enter {
    opacity: 0;
    transform: translateY(40px) scale(0.97);
    animation: photo-enter 1.6s cubic-bezier(0.32, 0.72, 0, 1) 0.15s forwards;
    will-change: transform, opacity;
  }
  @keyframes photo-enter {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes pulse-soft {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.5; }
  }
  .pulse-soft { animation: pulse-soft 2.6s ease-in-out infinite; }

  /* mouse parallax photo */
  .photo-parallax {
    will-change: transform;
    transition: transform 0.9s cubic-bezier(0.32, 0.72, 0, 1);
  }

  /* custom cursor — hero only */
  .hero-cursor-on, .hero-cursor-on * { cursor: none !important; }
  @media (hover: none) { .hero-cursor-on, .hero-cursor-on * { cursor: auto !important; } }
  #cursor-dot, #cursor-ring {
    position: fixed;
    top: 0; left: 0;
    border-radius: 9999px;
    pointer-events: none;
    z-index: 60;
    will-change: transform;
    transform: translate3d(-100px, -100px, 0);
    mix-blend-mode: difference;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  body.hero-cursor-visible #cursor-dot,
  body.hero-cursor-visible #cursor-ring { opacity: 1; }
  #cursor-dot { width: 4px; height: 4px; background: #ffffff; }
  #cursor-ring {
    width: 26px; height: 26px;
    border: 1px solid rgba(255,255,255,0.5);
    transition: width 0.4s cubic-bezier(0.32,0.72,0,1), height 0.4s cubic-bezier(0.32,0.72,0,1), opacity 0.3s ease;
  }
  body.cursor-active #cursor-ring { width: 56px; height: 56px; border-color: rgba(255,255,255,0.95); }
  @media (hover: none) { #cursor-dot, #cursor-ring { display: none; } }

  .magnet { will-change: transform; transition: transform 0.5s cubic-bezier(0.32,0.72,0,1), background 0.4s; }

  /* word hover behaviour */
  h1 .hl-word, h1 .hl-accent { transition: opacity 0.5s ease, color 0.5s ease; }
  h1:hover .hl-word { opacity: 0.4; }
  h1:hover .hl-word:hover { opacity: 1; }
  h1:hover .hl-accent { opacity: 1; color: #BCD0FF; }

  /* quiet underline link */
  .quiet-link { position: relative; transition: color 0.3s; }
  .quiet-link::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.55s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .quiet-link:hover::after { transform: scaleX(1); transform-origin: left; }

  /* tiny rotation marker on photo, like a specimen tag */
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .spin-slow { animation: spin-slow 60s linear infinite; }

  @media (prefers-reduced-motion: reduce) {
    .reveal-line > .reveal-inner, .fade-up, .photo-enter, .photo-img, .spin-slow {
      animation: none !important; transform: none !important; opacity: 1 !important;
    }
  }
</style>

<div id="cursor-dot" aria-hidden="true"></div>
<div id="cursor-ring" aria-hidden="true"></div>

<section class="hero-bg relative h-[100dvh] min-h-[700px] overflow-hidden flex flex-col">

  <!-- Network mesh canvas — geometric infrastructure -->
  <canvas id="hero-net" class="absolute inset-0 w-full h-full pointer-events-none" style="z-index: 2; opacity: 0.95;"></canvas>

  <!-- Top thin strip -->
  <div class="relative z-20 shrink-0">
    <div class="max-w-[1500px] mx-auto px-6 lg:px-14">
      <div class="fade-up flex items-center justify-between pt-24 pb-5" style="animation-delay: 0.05s;">
        <div class="flex items-center gap-2.5 text-white/75 text-[15px]">
          <span class="serif-it text-[19px] text-white">Epromar</span>
          <span class="text-white/25">—</span>
          <span class="text-white/55">Celje, Slovenija</span>
        </div>

        <div class="hidden md:flex items-center gap-2.5 text-[13px]">
          {isOpen ? (
            <>
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 pulse-soft"></span>
              <span class="text-white/60">Pisarna odprta</span>
              <span class="text-white/25">·</span>
              <span class="text-white/40">do 16:00</span>
            </>
          ) : (
            <>
              <span class="w-1.5 h-1.5 rounded-full bg-white/30"></span>
              <span class="text-white/50">Pisarna zaprta</span>
              <span class="text-white/25">·</span>
              <span class="text-white/40">odpremo Pon 8:00</span>
            </>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Main grid -->
  <div class="relative z-10 flex-1 flex items-center w-full min-h-0">
    <div class="max-w-[1500px] mx-auto px-6 lg:px-14 w-full py-4">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-center">

        <!-- Left: editorial headline -->
        <div class="lg:col-span-7">

          <h1 class="text-white font-extrabold tracking-[-0.035em]" style="font-size: clamp(2.4rem, 5.4vw, 4.8rem); line-height: 1;">
            <span class="reveal-line l1">
              <span class="reveal-inner">
                <span class="hl-word">Servis,</span> <span class="hl-word">prodaja,</span>
              </span>
            </span>
            <span class="reveal-line l2">
              <span class="reveal-inner">
                <span class="hl-word">vzdrževanje</span> <span class="hl-word">in</span>
              </span>
            </span>
            <span class="reveal-line l3">
              <span class="reveal-inner">
                <span class="hl-accent serif-it" style="font-weight: 400; letter-spacing: -0.015em; padding-right: 0.05em;">povezovanje</span><span class="hl-word"> računalnikov.</span>
              </span>
            </span>
          </h1>

          <p class="fade-up text-white/55 text-base md:text-[17px] leading-[1.6] max-w-[55ch] mt-7 lg:mt-9" style="animation-delay: 0.7s;">
            Celostne IT rešitve za manjša in srednja podjetja v Celju in okolici. Servis, omrežna infrastruktura in outsourcing IT podpore — od leta 1993.
          </p>

          <div class="fade-up flex flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-7 mt-8" style="animation-delay: 0.85s;">
            <a href="#kontakt" class="magnet group inline-flex items-center justify-between gap-3 pl-7 pr-2 py-2 rounded-full bg-white text-[#0A0F1E] text-[15px] font-semibold hover:bg-[#E5EDFF]" data-magnetic>
              <span>Pošljite povpraševanje</span>
              <span class="w-10 h-10 rounded-full bg-[#0A0F1E] flex items-center justify-center group-hover:rotate-[-45deg] transition-transform duration-500" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);">
                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none">
                  <path d="M5 11 L11 5 M6 5 L11 5 L11 10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
            <a href="tel:+38634901190" class="quiet-link inline-flex items-center px-3 py-2.5 text-white/70 text-[15px] hover:text-white">
              03 490 11 90
            </a>
          </div>

        </div>

        <!-- Right: cinematic photo frame -->
        <div class="hidden lg:block lg:col-span-5">
          <div class="photo-enter photo-parallax" id="photo-parallax">
            <div class="photo-frame">
              <img class="photo-img" src={photoUrl} alt="Strežniška infrastruktura" loading="eager" />
              <div class="photo-tint"></div>
              <div class="photo-color"></div>
              <div class="photo-fade"></div>
              <div class="photo-corner-grid"></div>

              <div class="photo-content">
                <!-- Architectural corners -->
                <span class="corner corner-tl"></span>
                <span class="corner corner-tr"></span>
                <span class="corner corner-bl"></span>
                <span class="corner corner-br"></span>

                <!-- Bottom caption -->
                <div class="photo-caption">
                  servis · omrežja · strežniki · IT podpora
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom thin strip -->
  <div class="relative z-10 shrink-0 border-t border-white/[0.07]">
    <div class="max-w-[1500px] mx-auto px-6 lg:px-14">
      <div class="fade-up flex items-center justify-between py-4 text-white/45 text-[13px]" style="animation-delay: 1.0s;">
        <div class="flex items-center gap-3 sm:gap-4">
          <span>Kosovelova 16</span>
          <span class="text-white/15">·</span>
          <span class="hidden sm:inline">3000 Celje</span>
          <span class="hidden md:inline text-white/15">·</span>
          <a href="mailto:servis@epromar.si" class="quiet-link hidden md:inline hover:text-white">servis@epromar.si</a>
        </div>
        <span class="flex items-center gap-2 text-white/35">
          <span>Scroll</span>
          <span class="block w-5 h-px bg-white/25"></span>
        </span>
      </div>
    </div>
  </div>

</section>

<script>
  // Custom cursor
  const dot = document.getElementById('cursor-dot') as HTMLElement | null;
  const ring = document.getElementById('cursor-ring') as HTMLElement | null;
  const isFinePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  if (isFinePointer && dot && ring) {
    const heroSection = document.querySelector('section.hero-bg') as HTMLElement | null;
    let mx = window.innerWidth / 2, my = window.innerHeight / 2;
    let rx = mx, ry = my;

    window.addEventListener('mousemove', (e) => {
      mx = e.clientX; my = e.clientY;
      dot.style.transform = `translate3d(${mx - 2}px, ${my - 2}px, 0)`;
    });

    function loop() {
      rx += (mx - rx) * 0.16;
      ry += (my - ry) * 0.16;
      ring.style.transform = `translate3d(${rx - 13}px, ${ry - 13}px, 0)`;
      requestAnimationFrame(loop);
    }
    loop();

    if (heroSection) {
      heroSection.classList.add('hero-cursor-on');
      heroSection.addEventListener('mouseenter', () => document.body.classList.add('hero-cursor-visible'));
      heroSection.addEventListener('mouseleave', () => {
        document.body.classList.remove('hero-cursor-visible');
        document.body.classList.remove('cursor-active');
      });

      heroSection.querySelectorAll('a, button, [data-magnetic]').forEach(el => {
        el.addEventListener('mouseenter', () => document.body.classList.add('cursor-active'));
        el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-active'));
      });
    }
  }

  // Magnetic CTA
  if (isFinePointer) {
    document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach(el => {
      const strength = 0.22;
      el.addEventListener('mousemove', (e) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        el.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = 'translate(0, 0)';
      });
    });
  }

  // Photo parallax
  const photo = document.getElementById('photo-parallax');
  if (photo && isFinePointer) {
    let raf = 0;
    window.addEventListener('mousemove', (e) => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const px = (e.clientX / window.innerWidth - 0.5) * 12;
        const py = (e.clientY / window.innerHeight - 0.5) * 12;
        photo.style.transform = `translate3d(${-px}px, ${-py}px, 0)`;
      });
    });
  }

  // ============ Network mesh canvas ============
  const netCanvas = document.getElementById('hero-net') as HTMLCanvasElement | null;
  if (netCanvas) {
    const ctx = netCanvas.getContext('2d')!;

    type Node = { x: number; y: number; vx: number; vy: number; type: 'dot' | 'ring'; baseSize: number };
    type Packet = { from: number; to: number; t: number; speed: number };

    let nodes: Node[] = [];
    let packets: Packet[] = [];
    let netMouse = { x: -1000, y: -1000 };
    let isVisible = true;
    let rafId = 0;
    const NUM = 60;
    const MAX_DIST = 180;

    function netResize() {
      netCanvas.width = window.innerWidth;
      netCanvas.height = window.innerHeight;
    }

    function netInit() {
      netResize();
      nodes = Array.from({ length: NUM }, () => ({
        x: Math.random() * netCanvas.width,
        y: Math.random() * netCanvas.height,
        vx: (Math.random() - 0.5) * 0.28,
        vy: (Math.random() - 0.5) * 0.28,
        type: Math.random() > 0.78 ? 'ring' : 'dot',
        baseSize: 1.1 + Math.random() * 1.3,
      }));
      packets = [];
    }

    function netSpawnPacket() {
      for (let attempts = 0; attempts < 12; attempts++) {
        const i = Math.floor(Math.random() * nodes.length);
        const j = Math.floor(Math.random() * nodes.length);
        if (i === j) continue;
        const dx = nodes[i].x - nodes[j].x;
        const dy = nodes[i].y - nodes[j].y;
        const dist = Math.hypot(dx, dy);
        if (dist < MAX_DIST && dist > 30) {
          packets.push({ from: i, to: j, t: 0, speed: 0.010 + Math.random() * 0.012 });
          return;
        }
      }
    }

    let packetTimer = window.setInterval(() => {
      if (isVisible && packets.length < 8) netSpawnPacket();
    }, 500);

    function netDraw() {
      ctx.clearRect(0, 0, netCanvas.width, netCanvas.height);

      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > netCanvas.width) n.vx *= -1;
        if (n.y < 0 || n.y > netCanvas.height) n.vy *= -1;
      }

      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const dist = Math.hypot(dx, dy);
          if (dist < MAX_DIST) {
            const midX = (nodes[i].x + nodes[j].x) / 2 - netMouse.x;
            const midY = (nodes[i].y + nodes[j].y) / 2 - netMouse.y;
            const mDist = Math.hypot(midX, midY);
            const boost = mDist < 300 ? 1 + ((300 - mDist) / 300) * 2.0 : 1;
            const alpha = Math.min((1 - dist / MAX_DIST) * 0.85 * boost, 1);
            ctx.strokeStyle = `rgba(150, 195, 255, ${alpha})`;
            ctx.lineWidth = 0.85;
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.stroke();
          }
        }
      }

      packets = packets.filter(p => {
        p.t += p.speed;
        if (p.t >= 1) return false;
        const f = nodes[p.from];
        const t = nodes[p.to];
        if (!f || !t) return false;
        const x = f.x + (t.x - f.x) * p.t;
        const y = f.y + (t.y - f.y) * p.t;
        const fade = Math.sin(p.t * Math.PI);
        ctx.shadowColor = 'rgba(120, 170, 255, 1)';
        ctx.shadowBlur = 18;
        ctx.fillStyle = `rgba(210, 230, 255, ${fade})`;
        ctx.beginPath();
        ctx.arc(x, y, 2.2, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
        return true;
      });

      for (const n of nodes) {
        const dx = n.x - netMouse.x;
        const dy = n.y - netMouse.y;
        const mDist = Math.hypot(dx, dy);
        const proximity = mDist < 260 ? (260 - mDist) / 260 : 0;
        const size = n.baseSize + proximity * 1.8;
        const alpha = 0.85 + proximity * 0.15;

        if (n.type === 'ring') {
          ctx.strokeStyle = `rgba(180, 215, 255, ${alpha})`;
          ctx.lineWidth = 1.1;
          ctx.beginPath();
          ctx.arc(n.x, n.y, size + 1.6, 0, Math.PI * 2);
          ctx.stroke();
          ctx.shadowColor = 'rgba(120, 170, 255, 0.6)';
          ctx.shadowBlur = 8;
          ctx.fillStyle = `rgba(220, 235, 255, ${alpha})`;
          ctx.beginPath();
          ctx.arc(n.x, n.y, Math.max(size * 0.55, 0.9), 0, Math.PI * 2);
          ctx.fill();
          ctx.shadowBlur = 0;
        } else {
          ctx.shadowColor = 'rgba(120, 170, 255, 0.5)';
          ctx.shadowBlur = 6;
          ctx.fillStyle = `rgba(210, 230, 255, ${alpha})`;
          ctx.beginPath();
          ctx.arc(n.x, n.y, size, 0, Math.PI * 2);
          ctx.fill();
          ctx.shadowBlur = 0;
        }
      }

      rafId = requestAnimationFrame(netDraw);
    }

    window.addEventListener('mousemove', (e) => {
      if (!isVisible) return;
      netMouse.x = e.clientX;
      netMouse.y = e.clientY;
    });

    // Pause canvas when hero scrolls off-screen
    const heroSec = document.querySelector('section.hero-bg');
    if (heroSec && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !isVisible) {
            isVisible = true;
            rafId = requestAnimationFrame(netDraw);
          } else if (!e.isIntersecting && isVisible) {
            isVisible = false;
            cancelAnimationFrame(rafId);
          }
        }
      }, { threshold: 0 });
      io.observe(heroSec);
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden && isVisible) {
        isVisible = false;
        cancelAnimationFrame(rafId);
      } else if (!document.hidden) {
        isVisible = true;
        rafId = requestAnimationFrame(netDraw);
      }
    });

    netInit();
    netDraw();
    window.addEventListener('resize', netInit);
  }
</script>
