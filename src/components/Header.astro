---
const navLinks = [
  { href: '#storitve',   label: 'Storitve' },
  { href: '#o-podjetju', label: 'O podjetju' },
  { href: '#reference',  label: 'Reference' },
  { href: '#kontakt',    label: 'Kontakt' },
];
---

<style>
  #main-header {
    transition: background-color 0.4s cubic-bezier(0.32, 0.72, 0, 1), border-color 0.4s ease, padding 0.3s ease;
    border-bottom: 1px solid transparent;
  }
  #main-header.scrolled {
    background-color: rgba(10, 15, 30, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  /* Nav links */
  .nav-link {
    position: relative;
    color: rgba(255, 255, 255, 0.65);
    transition: color 0.3s;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -3px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.55s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .nav-link:hover { color: #ffffff; }
  .nav-link:hover::after { transform: scaleX(1); transform-origin: left; }

  /* CTA pill */
  .header-cta {
    transition: background 0.4s, transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .header-cta:hover { background: #BCD0FF; transform: translateY(-1px); }
  .header-cta .cta-arrow { transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1); }
  .header-cta:hover .cta-arrow { transform: rotate(-45deg); }

  /* Logo wrapper */
  .logo-wrap {
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .logo-wrap:hover { transform: translateY(-1px); }

  /* Mobile menu */
  #mobile-menu {
    background-color: rgba(10, 15, 30, 0.95);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-top-color: rgba(255, 255, 255, 0.06);
  }
</style>

<header id="main-header" class="fixed top-0 left-0 right-0 z-50">
  <div class="max-w-[1500px] mx-auto px-5 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-[72px]">

      <!-- Logo -->
      <a href="/" class="logo-wrap inline-flex items-center bg-white rounded-lg px-3 py-1.5 shadow-sm">
        <img src="/epromar-celje-logo_0.gif" alt="Epromar — Celje" class="h-7 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-9 lg:gap-10">
        {navLinks.map(link => (
          <a href={link.href} class="nav-link text-[14px] font-medium tracking-tight">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <a
        href="#kontakt"
        class="header-cta hidden md:inline-flex items-center gap-2 pl-4 pr-1 py-1 rounded-full bg-white text-[#0A0F1E] text-[13px] font-semibold"
      >
        <span>Kontaktirajte nas</span>
        <span class="w-7 h-7 rounded-full bg-[#0A0F1E] flex items-center justify-center cta-arrow">
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
            <path d="M3 6 L9 6 M6 3 L9 6 L6 9" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>

      <!-- Mobile toggle -->
      <button id="menu-toggle" class="md:hidden p-2 text-white/85" aria-label="Odpri meni">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t">
    <nav class="flex flex-col px-5 py-5 gap-1">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link text-[15px] font-medium py-2">
          {link.label}
        </a>
      ))}
      <a href="#kontakt" class="inline-flex justify-center items-center gap-2 mt-4 px-4 py-2.5 bg-white text-[#0A0F1E] text-[13px] font-semibold rounded-full">
        <span>Kontaktirajte nas</span>
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M3 6 L9 6 M6 3 L9 6 L6 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) header?.classList.add('scrolled');
    else                     header?.classList.remove('scrolled');
  }, { passive: true });

  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.add('hidden')));
</script>
