---
const services = [
  { value: 'servis',         label: 'servisu računalnikov',     subject: 'Servis računalnikov' },
  { value: 'vzdrzevanje',    label: 'pogodbenem vzdrževanju',   subject: 'Pogodbeno vzdrževanje' },
  { value: 'outsourcing',    label: 'outsourcingu IT podpore',  subject: 'Outsourcing IT podpore' },
  { value: 'omrezje',        label: 'omrežni infrastrukturi',   subject: 'Omrežna infrastruktura' },
  { value: 'oddaljena',      label: 'oddaljeni pomoči',         subject: 'Oddaljena pomoč' },
  { value: 'prodaja',        label: 'prodaji opreme',           subject: 'Prodaja opreme' },
  { value: 'spletne',        label: 'spletnih storitvah',       subject: 'Spletne storitve' },
  { value: 'sistemi',        label: 'sistemih in OS',           subject: 'Sistemi in OS' },
  { value: 'drugo',          label: 'drugem',                   subject: 'Splošno povpraševanje' },
];

const now = new Date();
const day = now.getDay();
const hour = now.getHours();
const isOpen = day >= 1 && day <= 5 && hour >= 8 && hour < 16;
---

<style>
  .serif-it { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; }
  .mono     { font-family: 'JetBrains Mono', ui-monospace, monospace; }

  /* ============ Background ============ */
  .kontakt-bg {
    background-color: #0A0F1E;
    position: relative;
  }
  .k-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(110px);
    pointer-events: none;
    will-change: transform;
  }
  .k-orb-1 {
    width: 65vw; height: 65vw;
    top: -25vw; right: -20vw;
    background: radial-gradient(circle, rgba(27,60,143,0.55), transparent 65%);
    animation: k-drift-1 32s ease-in-out infinite alternate;
  }
  .k-orb-2 {
    width: 50vw; height: 50vw;
    bottom: -25vw; left: -15vw;
    background: radial-gradient(circle, rgba(77,142,255,0.35), transparent 65%);
    animation: k-drift-2 36s ease-in-out infinite alternate;
  }
  @keyframes k-drift-1 { 0% { transform: translate(0,0); } 100% { transform: translate(-8vw, 6vw) scale(1.12); } }
  @keyframes k-drift-2 { 0% { transform: translate(0,0); } 100% { transform: translate(7vw, -5vw) scale(1.18); } }

  .kontakt-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/></svg>");
    opacity: 0.04;
    pointer-events: none;
    mix-blend-mode: overlay;
    z-index: 1;
  }

  /* ============ Reveal animations ============ */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 1.2s cubic-bezier(0.32, 0.72, 0, 1), transform 1.2s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .reveal.in { opacity: 1; transform: translateY(0); }
  .reveal-d1 { transition-delay: 0.1s; }
  .reveal-d2 { transition-delay: 0.2s; }
  .reveal-d3 { transition-delay: 0.3s; }
  .reveal-d4 { transition-delay: 0.45s; }

  .mask-line { overflow: hidden; display: block; line-height: 1; }
  .mask-line > .mask-inner {
    display: inline-block;
    transform: translateY(108%);
    transition: transform 1.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .mask-line.in > .mask-inner { transform: translateY(0); }
  .mask-line.l1 > .mask-inner { transition-delay: 0.05s; }
  .mask-line.l2 > .mask-inner { transition-delay: 0.20s; }

  /* ============ The Letter Form ============ */
  .letter {
    color: rgba(255,255,255,0.85);
    font-size: clamp(1.15rem, 1.8vw, 1.45rem);
    line-height: 2.05;
    letter-spacing: -0.005em;
  }
  .letter-greeting {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: #ffffff;
    font-size: clamp(2rem, 3.2vw, 2.6rem);
    line-height: 1;
    margin-bottom: 1.6rem;
    letter-spacing: -0.015em;
  }
  .letter-closing {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: #ffffff;
    font-size: clamp(1.6rem, 2.4vw, 2rem);
    line-height: 1;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.012em;
  }

  .li-input, .li-select, .li-textarea {
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(255,255,255,0.22);
    color: #ffffff;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    padding: 0 6px 4px;
    outline: none;
    transition: border-color 0.4s cubic-bezier(0.32, 0.72, 0, 1), background 0.4s, color 0.3s;
    caret-color: #4D8EFF;
  }
  .li-input { display: inline-block; min-width: 9ch; field-sizing: content; max-width: 28ch; }
  .li-select { display: inline-block; appearance: none; -webkit-appearance: none; cursor: pointer; padding-right: 22px; min-width: 16ch; background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' stroke='rgba(255,255,255,0.5)' stroke-width='1.2' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>"); background-repeat: no-repeat; background-position: right 4px center; }
  .li-select option { background: #0A0F1E; color: #ffffff; font-style: normal; }
  .li-input::placeholder, .li-textarea::placeholder { color: rgba(255,255,255,0.32); font-family: 'Instrument Serif', Georgia, serif; font-style: italic; }

  .li-input:focus, .li-select:focus, .li-textarea:focus {
    border-color: #4D8EFF;
    background: rgba(77,142,255,0.06);
  }

  .li-input:invalid:not(:placeholder-shown) {
    border-color: #f87171;
  }

  .li-textarea {
    display: block;
    width: 100%;
    resize: vertical;
    min-height: 120px;
    margin-top: 1.2rem;
    margin-bottom: 1.2rem;
    padding: 12px 14px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    line-height: 1.55;
    font-size: clamp(0.95rem, 1.15vw, 1rem);
  }

  /* Letter paragraph spacing */
  .letter-para { margin-bottom: 1.4rem; }

  /* Submit button */
  .send-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 8px 8px 28px;
    border-radius: 9999px;
    background: #ffffff;
    color: #0A0F1E;
    font-size: 15px;
    font-weight: 600;
    will-change: transform;
    transition: background 0.4s, transform 0.45s cubic-bezier(0.32, 0.72, 0, 1);
    cursor: pointer;
    border: 0;
  }
  .send-btn:hover { background: #BCD0FF; }
  .send-btn .send-arrow {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #0A0F1E;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.55s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .send-btn:hover .send-arrow { transform: rotate(-45deg); }

  /* Form sent state */
  .form-sent .send-btn { background: rgba(52, 211, 153, 0.95); color: #0A0F1E; }

  /* ============ Reception Card ============ */
  .reception {
    position: relative;
    border-radius: 28px;
    padding: 1px;
    background: linear-gradient(160deg, rgba(77,142,255,0.4) 0%, rgba(255,255,255,0.04) 30%, rgba(77,142,255,0.18) 100%);
  }
  .reception-inner {
    border-radius: 27px;
    padding: 32px;
    background: linear-gradient(180deg, rgba(15,22,42,0.9) 0%, rgba(10,15,30,0.92) 100%);
    backdrop-filter: blur(20px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 30px 60px -30px rgba(0,0,0,0.6);
  }

  .info-row { padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .info-row:last-of-type { border-bottom: 0; }
  .info-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
  .info-value { color: rgba(255,255,255,0.88); font-size: 15px; line-height: 1.45; margin-top: 6px; }
  .info-link { color: rgba(255,255,255,0.88); transition: color 0.3s; }
  .info-link:hover { color: #4D8EFF; }

  /* Quick actions */
  .qa-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 22px; }
  .qa-btn {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 14px 8px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    background: rgba(255,255,255,0.02);
    color: rgba(255,255,255,0.85);
    transition: all 0.4s cubic-bezier(0.32, 0.72, 0, 1);
    cursor: pointer;
  }
  .qa-btn:hover {
    background: rgba(77,142,255,0.10);
    border-color: rgba(77,142,255,0.5);
    color: #ffffff;
    transform: translateY(-2px);
  }
  .qa-btn svg { transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1); }
  .qa-btn:hover svg { transform: scale(1.1); }
  .qa-label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; margin-top: 8px; font-family: 'JetBrains Mono', monospace; }

  /* Status pill */
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    border-radius: 9999px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
  }
  .status-open  { background: rgba(52, 211, 153, 0.10); color: rgb(110, 231, 183); border: 1px solid rgba(52, 211, 153, 0.25); }
  .status-closed { background: rgba(255, 255, 255, 0.04); color: rgba(255,255,255,0.5); border: 1px solid rgba(255, 255, 255, 0.12); }

  @keyframes pulse-emerald {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.45); }
    50%      { opacity: 0.55; box-shadow: 0 0 0 5px rgba(52, 211, 153, 0); }
  }
  .pulse-em { animation: pulse-emerald 2.4s ease-in-out infinite; }

  /* Closing statement underline animation */
  .close-rule {
    display: block;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.25), transparent);
    transform: scaleX(0);
    transition: transform 1.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .close-rule.in { transform: scaleX(1); }

  @media (prefers-reduced-motion: reduce) {
    .reveal, .reveal.in, .mask-line > .mask-inner, .mask-line.in > .mask-inner,
    .k-orb, .close-rule, .close-rule.in {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      animation: none !important;
    }
  }

  /* Safari/iOS field-sizing fallback */
  @supports not (field-sizing: content) {
    .li-input { width: 14ch; }
  }
</style>

<section id="kontakt" class="kontakt-bg py-28 lg:py-40 overflow-hidden">

  <div class="k-orb k-orb-1"></div>
  <div class="k-orb k-orb-2"></div>

  <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-16">

    <!-- ===== Header ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12 mb-20 lg:mb-28">
      <div class="lg:col-span-3">
        <div class="reveal flex items-center gap-3 lg:mt-4 reveal-d1">
          <span class="serif-it text-[#89B4FF] text-[19px] leading-none">Pogovorimo se</span>
          <span class="block w-12 h-px bg-white/25"></span>
        </div>
      </div>
      <div class="lg:col-span-9">
        <h2 class="text-white font-black tracking-[-0.04em]" style="font-size: clamp(2.2rem, 5.4vw, 5rem); line-height: 1.0;">
          <span class="mask-line l1"><span class="mask-inner">Vaš sistem ne sme čakati.</span></span>
          <span class="mask-line l2">
            <span class="mask-inner">
              Niti <span class="serif-it text-[#89B4FF]" style="font-weight: 400;">naš odziv.</span>
            </span>
          </span>
        </h2>
      </div>
    </div>

    <!-- ===== Body grid ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

      <!-- ===== LEFT: The Letter Form ===== -->
      <div class="lg:col-span-7">
        <form id="kontakt-form" class="reveal" novalidate>

          <div class="letter-greeting">Spoštovani,</div>

          <div class="letter">
            <p class="letter-para">
              sem
              <input type="text" name="ime" required placeholder="vaše ime" class="li-input" autocomplete="name" />
              iz podjetja
              <input type="text" name="podjetje" placeholder="naziv podjetja" class="li-input" autocomplete="organization" />.
            </p>

            <p class="letter-para">
              Potrebujemo pomoč pri
              <select name="storitev" required class="li-select">
                <option value="" disabled selected>izberite storitev</option>
                {services.map(s => <option value={s.value}>{s.label}</option>)}
              </select>.
            </p>

            <textarea name="sporocilo" placeholder="Opišite, kaj potrebujete — težavo, projekt, časovni okvir..." class="li-textarea"></textarea>

            <p class="letter-para">
              Pišite mi na
              <input type="email" name="email" required placeholder="e-pošta" class="li-input" autocomplete="email" />
              <span class="opacity-60">ali pokličite na</span>
              <input type="tel" name="telefon" placeholder="telefon" class="li-input" autocomplete="tel" />.
            </p>
          </div>

          <div class="letter-closing">Lep pozdrav.</div>

          <div class="mt-8 flex items-center gap-6 flex-wrap">
            <button type="submit" class="send-btn">
              <span>Pošljite pismo</span>
              <span class="send-arrow">
                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none">
                  <path d="M5 11 L11 5 M6 5 L11 5 L11 10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
            <span class="text-white/40 text-[12px] tracking-[0.18em] uppercase mono">
              Odgovorimo v <span class="text-white/70">24 urah</span>
            </span>
          </div>

          <div id="form-msg" class="mt-5 text-[14px] hidden"></div>

        </form>
      </div>

      <!-- ===== RIGHT: Reception Card ===== -->
      <div class="lg:col-span-5">
        <div class="reveal reveal-d2 reception">
          <div class="reception-inner">

            <!-- Brand mark -->
            <div class="flex items-end justify-between gap-4 mb-5">
              <div>
                <div class="serif-it text-white text-[30px] leading-none">Epromar</div>
                <div class="mono text-[10px] tracking-[0.22em] uppercase text-white/40 mt-1.5">d.o.o. — Celje, SI</div>
              </div>
              {isOpen ? (
                <span class="status-pill status-open">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 pulse-em"></span>
                  <span>Odprti</span>
                </span>
              ) : (
                <span class="status-pill status-closed">
                  <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                  <span>Zaprti</span>
                </span>
              )}
            </div>

            <div class="h-px w-full bg-gradient-to-r from-white/20 via-white/8 to-transparent mb-2"></div>

            <!-- Info rows -->
            <div class="info-row">
              <div class="info-label">Sedež</div>
              <div class="info-value">
                Kosovelova 16<br/>
                <span class="text-white/55">3000 Celje, Slovenija</span>
              </div>
            </div>

            <div class="info-row">
              <div class="info-label">Direktni stik</div>
              <div class="info-value space-y-1">
                <a href="tel:+38634901190" class="info-link block">03 490 11 90</a>
                <a href="mailto:servis@epromar.si" class="info-link block">servis@epromar.si</a>
              </div>
            </div>

            <div class="info-row">
              <div class="info-label">Delovni čas</div>
              <div class="info-value">
                Ponedeljek — Petek<br/>
                <span class="text-white/55">8:00 — 16:00</span>
              </div>
            </div>

            <div class="info-row">
              <div class="info-label">Področje delovanja</div>
              <div class="info-value">
                Celje in <span class="text-white/55">savinjska regija</span>
              </div>
            </div>

            <!-- Quick actions -->
            <div class="qa-row">
              <a href="tel:+38634901190" class="qa-btn" aria-label="Pokličite">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="qa-label">Klic</span>
              </a>
              <a href="mailto:servis@epromar.si" class="qa-btn" aria-label="Pošljite e-pošto">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="qa-label">Pošta</span>
              </a>
              <a href="https://maps.google.com/?q=Kosovelova+16+3000+Celje+Slovenija" target="_blank" rel="noopener" class="qa-btn" aria-label="Prikaži pot">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.4"/>
                </svg>
                <span class="qa-label">Smer</span>
              </a>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- ===== Closing ===== -->
    <div class="reveal reveal-d3 mt-28 lg:mt-36">
      <span class="close-rule mb-10"></span>
      <div class="text-center">
        <p class="serif-it text-white/85 mx-auto" style="font-size: clamp(1.5rem, 2.6vw, 2.2rem); line-height: 1.25; max-width: 28ch;">
          Naslednje leto bomo še tu.<br/>
          <span class="text-white/45">Računalniki ne počivajo.</span>
        </p>
      </div>
    </div>

  </div>
</section>

<script>
  // Reveal observer
  const obs = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
    }
  }, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });

  document.querySelectorAll('#kontakt .reveal, #kontakt .mask-line, #kontakt .close-rule').forEach(el => obs.observe(el));

  // Form submission via mailto
  const form = document.getElementById('kontakt-form') as HTMLFormElement | null;
  const msg = document.getElementById('form-msg');
  const inlineLabels: Record<string, string> = {
    servis: 'servisu računalnikov',
    vzdrzevanje: 'pogodbenem vzdrževanju',
    outsourcing: 'outsourcingu IT podpore',
    omrezje: 'omrežni infrastrukturi',
    oddaljena: 'oddaljeni pomoči',
    prodaja: 'prodaji opreme',
    spletne: 'spletnih storitvah',
    sistemi: 'sistemih in OS',
    drugo: 'drugem',
  };
  const subjectLabels: Record<string, string> = {
    servis: 'Servis računalnikov',
    vzdrzevanje: 'Pogodbeno vzdrževanje',
    outsourcing: 'Outsourcing IT podpore',
    omrezje: 'Omrežna infrastruktura',
    oddaljena: 'Oddaljena pomoč',
    prodaja: 'Prodaja opreme',
    spletne: 'Spletne storitve',
    sistemi: 'Sistemi in OS',
    drugo: 'Splošno povpraševanje',
  };

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const data = new FormData(form);
    const ime       = (data.get('ime') || '').toString().trim();
    const podjetje  = (data.get('podjetje') || '').toString().trim();
    const storitevKey = (data.get('storitev') || '').toString();
    const inlineLabel = inlineLabels[storitevKey] || 'pomoči';
    const subjectLabel = subjectLabels[storitevKey] || 'Povpraševanje';
    const sporocilo = (data.get('sporocilo') || '').toString().trim();
    const email     = (data.get('email') || '').toString().trim();
    const telefon   = (data.get('telefon') || '').toString().trim();

    const subject = `Povpraševanje — ${subjectLabel}${podjetje ? ` (${podjetje})` : ''}`;
    const lines = [
      'Spoštovani,',
      '',
      `sem ${ime}${podjetje ? `, iz podjetja ${podjetje}` : ''}.`,
      '',
      `Potrebujemo pomoč pri ${inlineLabel}.`,
      '',
    ];
    if (sporocilo) {
      lines.push(sporocilo, '');
    }
    lines.push(`Pišite mi na ${email}${telefon ? ` ali pokličite na ${telefon}` : ''}.`);
    lines.push('', 'Lep pozdrav,', ime);

    const body = lines.join('\n');
    const url = `mailto:servis@epromar.si?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = url;

    if (msg) {
      msg.classList.remove('hidden');
      msg.classList.add('text-emerald-300');
      msg.textContent = 'Odpiramo vaš e-poštni program — pošljite pismo iz njega in odgovorili bomo v 24 urah.';
    }
    form.classList.add('form-sent');
  });
</script>
