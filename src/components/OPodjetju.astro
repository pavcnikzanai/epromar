---
const stats = [
  { value: 33,   suffix: '',  label: 'let v poslu',           noCount: false },
  { value: 40,   suffix: '+', label: 'aktivnih partnerjev',   noCount: false },
  { value: 8,    suffix: '',  label: 'kategorij storitev',    noCount: false },
  { value: 1993, suffix: '',  label: 'leto ustanovitve',      noCount: true  },
];

const milestones = [
  { year: '1993', title: 'Ustanovitev v Celju',         body: 'Epromar d.o.o. je ustanovljen na Kosovelovi 16. Začetna storitev: servis računalnikov za lokalna podjetja.' },
  { year: '1998', title: 'Prvi outsourcing',            body: 'Prvi pogodbeni odnos za zunanje izvajanje IT podpore — premik k dolgoročnim partnerstvom.' },
  { year: '2003', title: 'Omrežna infrastruktura',      body: 'Razširitev storitev: projektiranje in postavitev optičnih ter bakrenih omrežij.' },
  { year: '2012', title: 'Vzdrževanje SMB',             body: 'Specializacija za pogodbeno vzdrževanje sistemov manjših in srednjih podjetij.' },
  { year: '2020', title: 'Oddaljena pomoč',             body: 'V času pandemije razširimo oddaljeno pomoč kot ključno storitev za stranke.' },
  { year: '2026', title: 'Današnji portfolio',          body: '40+ aktivnih partnerjev. 8 kategorij storitev. Pisarna še vedno na Kosovelovi 16.' },
];

const principles = [
  { title: 'Lokalno znanje', body: 'Trideset let v Celju. Poznamo okolje in stranke. Vsak obisk je oseben — ne preko ticketa.' },
  { title: 'Garancija',      body: 'Za vsako opravljeno delo. Brez drobnega tiska. Brez izgovorov, ko gre kaj narobe.' },
  { title: 'Hiter odziv',    body: 'Ko sistem stoji, podjetje stoji. Pridemo na lokacijo — pogosto že isti dan.' },
  { title: 'Brez paketov',   body: 'Vsak sistem je drugačen. Vsako rešitev gradimo posebej — ne kupujete tega, kar ne potrebujete.' },
];

const facts = [
  { label: 'Ustanovljeno',         value: '1993' },
  { label: 'Sedež',                value: 'Kosovelova 16, Celje' },
  { label: 'Specializacija',       value: 'Manjša in srednja podjetja' },
  { label: 'Aktivnih partnerjev',  value: '40+' },
  { label: 'Pisarna',              value: 'Pon–Pet · 8–16h' },
];
---

<style>
  .serif-it { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; }

  .opd-bg {
    background-color: #F7F4EC;
    position: relative;
  }
  .opd-bg::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle at 8% 5%, rgba(27, 60, 143, 0.06) 0%, transparent 38%),
      radial-gradient(circle at 92% 95%, rgba(27, 60, 143, 0.05) 0%, transparent 38%);
    pointer-events: none;
  }
  .opd-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.45'/></svg>");
    opacity: 0.045;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  /* Drop cap */
  .dropcap::first-letter {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    float: left;
    font-size: 4.6em;
    line-height: 0.88;
    margin-right: 0.08em;
    margin-top: 0.06em;
    color: #1B3C8F;
    font-weight: 400;
  }

  /* Reveal animations */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 1.2s cubic-bezier(0.32, 0.72, 0, 1), transform 1.2s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .reveal.in { opacity: 1; transform: translateY(0); }
  .reveal-d1 { transition-delay: 0.08s; }
  .reveal-d2 { transition-delay: 0.18s; }
  .reveal-d3 { transition-delay: 0.28s; }
  .reveal-d4 { transition-delay: 0.38s; }

  /* Mask reveal */
  .mask-line { overflow: hidden; display: block; line-height: 1; }
  .mask-line > .mask-inner {
    display: inline-block;
    transform: translateY(108%);
    transition: transform 1.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .mask-line.in > .mask-inner { transform: translateY(0); }
  .mask-line.l1 > .mask-inner { transition-delay: 0.05s; }
  .mask-line.l2 > .mask-inner { transition-delay: 0.20s; }
  .mask-line.l3 > .mask-inner { transition-delay: 0.35s; }

  /* Stats theater */
  .stat-num {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    line-height: 0.85;
    letter-spacing: -0.045em;
    color: #0A0F1E;
    background: linear-gradient(180deg, #0A0F1E 0%, #0A0F1E 65%, #1B3C8F 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Timeline */
  .tl-track {
    position: relative;
    padding-top: 100px;
  }
  .tl-line {
    position: absolute;
    top: 100px;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent 0%, rgba(10,15,30,0.25) 8%, rgba(10,15,30,0.25) 92%, transparent 100%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.8s cubic-bezier(0.32, 0.72, 0, 1) 0.2s;
  }
  .tl-track.in .tl-line { transform: scaleX(1); }

  .tl-item {
    position: relative;
    cursor: pointer;
  }
  .tl-dot {
    position: absolute;
    top: -6px;
    left: 0;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #F7F4EC;
    border: 1.5px solid rgba(10,15,30,0.4);
    transform: scale(0);
    transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1), background 0.4s, border-color 0.4s, box-shadow 0.4s;
  }
  .tl-track.in .tl-dot { transform: scale(1); }
  .tl-track.in .tl-item:nth-child(1) .tl-dot { transition-delay: 0.4s; }
  .tl-track.in .tl-item:nth-child(2) .tl-dot { transition-delay: 0.55s; }
  .tl-track.in .tl-item:nth-child(3) .tl-dot { transition-delay: 0.70s; }
  .tl-track.in .tl-item:nth-child(4) .tl-dot { transition-delay: 0.85s; }
  .tl-track.in .tl-item:nth-child(5) .tl-dot { transition-delay: 1.00s; }
  .tl-track.in .tl-item:nth-child(6) .tl-dot { transition-delay: 1.15s; }

  .tl-item:hover .tl-dot,
  .tl-item:focus-visible .tl-dot,
  .tl-item.active .tl-dot {
    background: #1B3C8F;
    border-color: #1B3C8F;
    box-shadow: 0 0 0 6px rgba(27,60,143,0.12), 0 0 0 12px rgba(27,60,143,0.06);
  }

  .tl-year {
    margin-top: 30px;
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 28px;
    line-height: 1;
    color: rgba(10,15,30,0.45);
    transition: color 0.4s, transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .tl-item:hover .tl-year,
  .tl-item:focus-visible .tl-year,
  .tl-item.active .tl-year {
    color: #1B3C8F;
    transform: translateY(-3px);
  }

  .tl-title {
    font-weight: 700;
    color: #0A0F1E;
    font-size: 14px;
    line-height: 1.3;
    margin-top: 12px;
    letter-spacing: -0.01em;
  }
  .tl-body {
    font-size: 13px;
    line-height: 1.55;
    color: rgba(10,15,30,0.55);
    margin-top: 10px;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.6s cubic-bezier(0.32, 0.72, 0, 1), opacity 0.4s;
  }
  .tl-item:hover .tl-body,
  .tl-item:focus-visible .tl-body,
  .tl-item.active .tl-body {
    max-height: 8em;
    opacity: 1;
  }

  .tl-marker {
    position: absolute;
    top: -28px;
    left: -1px;
    width: 14px; height: 18px;
    border-left: 1px solid rgba(10,15,30,0.2);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .tl-item:hover .tl-marker,
  .tl-item:focus-visible .tl-marker,
  .tl-item.active .tl-marker { transform: scaleY(1); }

  /* Pull quote */
  .pq-mark {
    display: inline-block;
    width: 2rem; height: 1px;
    background: #1B3C8F;
    vertical-align: middle;
    margin-right: 0.7em;
    margin-bottom: 0.18em;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.2s cubic-bezier(0.32, 0.72, 0, 1) 0.3s;
  }
  .reveal.in .pq-mark { transform: scaleX(1); }

  /* Principles hover line */
  .principle .p-rule {
    height: 1px;
    background: #1B3C8F;
    transform: scaleX(0.18);
    transform-origin: left;
    transition: transform 0.7s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .principle:hover .p-rule { transform: scaleX(1); }

  /* Section divider */
  .div-rule {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(10,15,30,0.20), transparent);
    transform: scaleX(0);
    transition: transform 1.2s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .div-rule.in { transform: scaleX(1); }

  /* Signature */
  .signature {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    letter-spacing: -0.01em;
  }

  /* Stamp / seal at closing */
  .stamp {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 130px; height: 130px;
    border: 1px solid rgba(27,60,143,0.45);
    border-radius: 50%;
    color: #1B3C8F;
  }
  .stamp::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px dashed rgba(27,60,143,0.25);
    border-radius: 50%;
  }
  .stamp-text path { fill: rgba(27,60,143,0.85); font-family: 'JetBrains Mono', monospace; }
  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .stamp-rotate { animation: spin-slow 50s linear infinite; }

  @media (prefers-reduced-motion: reduce) {
    .reveal, .reveal.in, .mask-line > .mask-inner, .mask-line.in > .mask-inner,
    .pq-mark, .reveal.in .pq-mark, .tl-line, .tl-track.in .tl-line, .tl-dot,
    .tl-track.in .tl-dot, .div-rule, .div-rule.in, .stamp-rotate {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      animation: none !important;
    }
  }
</style>

<section id="o-podjetju" class="opd-bg py-28 lg:py-40 overflow-hidden">
  <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-16">

    <!-- ===== OPENING: eyebrow + massive statement ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12 mb-24 lg:mb-32">
      <div class="lg:col-span-3">
        <div class="reveal flex items-center gap-3 lg:mt-4 reveal-d1">
          <span class="serif-it text-[#1B3C8F] text-[19px] leading-none">Kdo smo</span>
          <span class="block w-12 h-px bg-[#0A0F1E]/20"></span>
        </div>
      </div>
      <div class="lg:col-span-9">
        <h2 class="text-[#0A0F1E] font-black tracking-[-0.04em]" style="font-size: clamp(2.2rem, 5.4vw, 5rem); line-height: 1.0;">
          <span class="mask-line l1"><span class="mask-inner">Začeli smo z enim</span></span>
          <span class="mask-line l2">
            <span class="mask-inner">
              <span class="serif-it text-[#1B3C8F]" style="font-weight: 400; padding-right: 0.04em;">računalnikom.</span>
            </span>
          </span>
          <span class="mask-line l3">
            <span class="mask-inner">Danes ne damo počivati nobenemu.</span>
          </span>
        </h2>
      </div>
    </div>

    <!-- ===== STATS THEATER ===== -->
    <div class="reveal mb-24 lg:mb-36">
      <div class="text-[#0A0F1E]/45 text-[11px] tracking-[0.24em] uppercase mb-10 flex items-center gap-3">
        <span class="block w-8 h-px bg-[#0A0F1E]/25"></span>
        <span>Trideset tri let v številkah</span>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 lg:gap-x-4">
        {stats.map((s, i) => (
          <div class="reveal stat-block" data-delay={i}>
            <div
              class="stat-num"
              data-target={s.value}
              data-suffix={s.suffix}
              data-nocount={s.noCount ? '1' : '0'}
              style="font-size: clamp(4.5rem, 9vw, 8.5rem);"
            >
              {s.noCount ? `${s.value}${s.suffix}` : `0${s.suffix}`}
            </div>
            <div class="mt-4 flex items-center gap-3">
              <span class="block w-6 h-px bg-[#1B3C8F]/40"></span>
              <span class="text-[#0A0F1E]/55 text-[12px] tracking-[0.18em] uppercase">{s.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- divider -->
    <div class="div-rule reveal mb-24 lg:mb-36"></div>

    <!-- ===== EDITORIAL BODY SPREAD ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 mb-24 lg:mb-36">

      <div class="lg:col-span-7">
        <div class="reveal text-[#0A0F1E]/80 text-[17px] leading-[1.72] max-w-[60ch] space-y-5">
          <p class="dropcap">
            Epromar je IT podjetje iz Celja, ustanovljeno leta 1993. Servis, prodaja in vzdrževanje računalniške opreme ter omrežne infrastrukture za manjša in srednja podjetja — to delamo več kot tri desetletja.
          </p>
          <p>
            V tem času smo postali zanesljiv partner podjetjem, ki si izpadov sistema ne morejo privoščiti. Stranke obiščemo na lokaciji, težave odpravimo hitro, in za opravljeno delo vedno nudimo garancijo.
          </p>
          <p>
            Ne prodajamo standardnih paketov. Vsak sistem je drugačen, zato vsako rešitev gradimo posebej — od osnovne servisne oskrbe do pogodbenega vzdrževanja in outsourcinga IT podpore.
          </p>
        </div>

        <div class="reveal reveal-d2 mt-10 flex items-center gap-3">
          <span class="signature text-[#1B3C8F] text-[22px] leading-none">— Ekipa Epromar</span>
          <span class="block w-8 h-px bg-[#0A0F1E]/20"></span>
          <span class="text-[#0A0F1E]/45 text-[12px] tracking-[0.18em] uppercase">Celje, 1993</span>
        </div>
      </div>

      <div class="lg:col-span-5 lg:pl-6">
        <blockquote class="reveal serif-it text-[#0A0F1E] leading-[1.18]" style="font-size: clamp(1.5rem, 2.6vw, 2.3rem); letter-spacing: -0.012em;">
          <span class="pq-mark"></span>Vsak računalniški sistem ima svojo zgodbo. Po treh desetletjih jo prebiramo na prvi pogled.
        </blockquote>

        <div class="reveal reveal-d2 mt-12">
          <div class="text-[#0A0F1E]/45 text-[11px] tracking-[0.22em] uppercase mb-5">Profil podjetja</div>
          <dl class="space-y-px">
            {facts.map((f) => (
              <div class="flex items-baseline justify-between gap-4 py-3 border-b border-[#0A0F1E]/10">
                <dt class="text-[#0A0F1E]/55 text-[13px]">{f.label}</dt>
                <dd class="text-[#0A0F1E] text-[14px] font-semibold tabular-nums">{f.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>

    <!-- divider -->
    <div class="div-rule reveal mb-24 lg:mb-32"></div>

    <!-- ===== INTERACTIVE TIMELINE ===== -->
    <div class="mb-24 lg:mb-36">
      <div class="reveal grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12 mb-12 lg:mb-16">
        <div class="lg:col-span-3">
          <div class="flex items-center gap-3 lg:mt-3">
            <span class="serif-it text-[#1B3C8F] text-[19px] leading-none">Naša zgodba</span>
            <span class="block w-12 h-px bg-[#0A0F1E]/20"></span>
          </div>
        </div>
        <div class="lg:col-span-9">
          <h3 class="text-[#0A0F1E] font-black tracking-[-0.025em]" style="font-size: clamp(1.75rem, 3.4vw, 3rem); line-height: 1.05;">
            <span class="serif-it text-[#1B3C8F]">1993</span> — <span class="serif-it text-[#1B3C8F]">2026</span><br/>
            v šestih ključnih trenutkih.
          </h3>
        </div>
      </div>

      <div class="tl-track reveal" id="tl-track">
        <div class="tl-line"></div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-y-16 gap-x-6 lg:gap-x-4">
          {milestones.map((m) => (
            <div class="tl-item" tabindex="0">
              <span class="tl-marker"></span>
              <span class="tl-dot"></span>
              <div class="tl-year">{m.year}</div>
              <h4 class="tl-title">{m.title}</h4>
              <p class="tl-body">{m.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- divider -->
    <div class="div-rule reveal mb-24 lg:mb-32"></div>

    <!-- ===== PRINCIPLES ===== -->
    <div class="mb-24 lg:mb-36">
      <div class="reveal text-[#0A0F1E]/45 text-[11px] tracking-[0.22em] uppercase mb-10 flex items-center gap-3">
        <span class="block w-8 h-px bg-[#0A0F1E]/25"></span>
        <span>Kako delamo</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-y-14 gap-x-10 lg:gap-x-0">
        {principles.map((p, i) => (
          <div class={`principle reveal lg:px-8 ${i === 0 ? 'lg:pl-0' : ''} ${i === principles.length - 1 ? 'lg:pr-0' : ''} ${i > 0 ? 'lg:border-l lg:border-[#0A0F1E]/10' : ''}`}>
            <div class="p-rule w-10 mb-4"></div>
            <h3 class="serif-it text-[#0A0F1E] text-[28px] lg:text-[30px] leading-[1.05] mb-4 tracking-[-0.005em]">
              {p.title}
            </h3>
            <p class="text-[#0A0F1E]/65 text-[14px] leading-[1.65] max-w-[36ch]">{p.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- ===== CLOSING — stamp + statement ===== -->
    <div class="reveal flex flex-col items-center text-center pt-8">

      <div class="stamp mb-10">
        <svg class="stamp-rotate absolute inset-0 w-full h-full" viewBox="0 0 200 200">
          <defs>
            <path id="stampCircle" d="M 100,100 m -76,0 a 76,76 0 1,1 152,0 a 76,76 0 1,1 -152,0"/>
          </defs>
          <text class="stamp-text" font-size="11" letter-spacing="3.5">
            <textPath href="#stampCircle">EPROMAR · CELJE · SLOVENIJA · 1993 — 2026 · </textPath>
          </text>
        </svg>
        <div class="text-center">
          <div class="serif-it text-[34px] leading-none">E</div>
          <div class="text-[8px] tracking-[0.3em] uppercase mt-1.5 text-[#1B3C8F]/70">est. 93</div>
        </div>
      </div>

      <h3 class="serif-it text-[#0A0F1E] leading-[1.15] max-w-[24ch]" style="font-size: clamp(1.7rem, 3vw, 2.6rem);">
        Naslednje leto bomo še tu.<br/>
        <span class="text-[#0A0F1E]/55">Računalniki ne počivajo.</span>
      </h3>

      <a href="#kontakt" class="mt-10 inline-flex items-center gap-3 group">
        <span class="text-[#0A0F1E] text-[14px] font-semibold">Pogovorimo se</span>
        <span class="w-10 h-10 rounded-full border border-[#0A0F1E]/30 flex items-center justify-center group-hover:bg-[#0A0F1E] group-hover:border-[#0A0F1E] transition-all duration-500" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);">
          <svg class="w-3 h-3 text-[#0A0F1E] group-hover:text-white transition-colors" viewBox="0 0 12 12" fill="none">
            <path d="M3 6 L9 6 M6 3 L9 6 L6 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>

    </div>

  </div>
</section>

<script>
  // ============ Reveal observer ============
  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        entry.target.classList.add('in');

        // count-up for stats
        if (entry.target.classList.contains('stat-block')) {
          const numEl = entry.target.querySelector('.stat-num') as HTMLElement | null;
          if (numEl && numEl.dataset.nocount !== '1') {
            const target = parseInt(numEl.dataset.target || '0', 10);
            const suffix = numEl.dataset.suffix || '';
            const duration = 1500;
            const start = performance.now();
            const tick = (t: number) => {
              const p = Math.min((t - start) / duration, 1);
              const eased = 1 - Math.pow(1 - p, 4);
              const v = Math.floor(target * eased);
              numEl.textContent = `${v}${suffix}`;
              if (p < 1) requestAnimationFrame(tick);
              else numEl.textContent = `${target}${suffix}`;
            };
            requestAnimationFrame(tick);
          }
        }

        observer.unobserve(entry.target);
      }
    }
  }, { threshold: 0.2, rootMargin: '0px 0px -8% 0px' });

  document.querySelectorAll('#o-podjetju .reveal, #o-podjetju .mask-line, #o-podjetju .div-rule, #o-podjetju .tl-track').forEach((el) => {
    observer.observe(el);
  });

  // ============ Timeline keyboard activation (sticky on focus/click for touch) ============
  const tlItems = document.querySelectorAll<HTMLElement>('.tl-item');
  tlItems.forEach((el) => {
    el.addEventListener('click', () => {
      tlItems.forEach(o => o.classList.remove('active'));
      el.classList.add('active');
    });
  });
</script>
