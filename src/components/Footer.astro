---
const leto = new Date().getFullYear();

const storitveLinks = [
  { label: 'Servis računalnikov',     href: '#storitve' },
  { label: 'Pogodbeno vzdrževanje',   href: '#storitve' },
  { label: 'Outsourcing IT',          href: '#storitve' },
  { label: 'Omrežna infrastruktura',  href: '#storitve' },
  { label: 'Oddaljena pomoč',         href: '#storitve' },
  { label: 'Spletne storitve',        href: '#storitve' },
];

const podjetjeLinks = [
  { label: 'Kdo smo',                 href: '#o-podjetju' },
  { label: 'Naša zgodba',             href: '#o-podjetju' },
  { label: 'Reference',               href: '#reference' },
  { label: 'Kontakt',                 href: '#kontakt' },
];
---

<style>
  .serif-it { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; }
  .mono     { font-family: 'JetBrains Mono', ui-monospace, monospace; }

  .ftr-bg {
    background: #050810;
    position: relative;
  }
  .ftr-bg::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(27, 60, 143, 0.18) 0%, transparent 60%);
    pointer-events: none;
  }
  .ftr-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.55'/></svg>");
    opacity: 0.04;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .ftr-link {
    position: relative;
    display: inline-block;
    color: rgba(255,255,255,0.65);
    transition: color 0.3s;
  }
  .ftr-link::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.55s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .ftr-link:hover { color: #ffffff; }
  .ftr-link:hover::after { transform: scaleX(1); transform-origin: left; }

  /* Massive wordmark — bleeds */
  .wordmark {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(6rem, 22vw, 22rem);
    line-height: 0.85;
    letter-spacing: -0.05em;
    background: linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(77,142,255,0.18) 60%, rgba(27,60,143,0.06) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    user-select: none;
    pointer-events: none;
  }

  @keyframes pulse-em {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.55; }
  }
  .pulse-em { animation: pulse-em 2.6s ease-in-out infinite; }

  @media (prefers-reduced-motion: reduce) {
    .pulse-em { animation: none !important; }
  }
</style>

<footer class="ftr-bg relative overflow-hidden">

  <div class="relative z-10 max-w-[1500px] mx-auto px-6 lg:px-16 pt-24 lg:pt-32 pb-10">

    <!-- Top: 4-col grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 lg:gap-12 mb-20 lg:mb-24">

      <!-- Brand block -->
      <div class="md:col-span-5">
        <div class="serif-it text-white text-[44px] lg:text-[56px] leading-none mb-3">Epromar</div>
        <div class="mono text-[10px] tracking-[0.22em] uppercase text-white/40 mb-7">d.o.o. — Celje, Slovenija — Est. 1993</div>

        <p class="text-white/60 text-[15px] leading-[1.65] max-w-[40ch] mb-8">
          Servis, prodaja, vzdrževanje in povezovanje računalnikov za manjša in srednja podjetja v Celju in okolici.
        </p>

        <a href="#kontakt" class="inline-flex items-center gap-3 group">
          <span class="text-white text-[14px] font-semibold">Pogovorimo se</span>
          <span class="w-9 h-9 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-white group-hover:border-white transition-all duration-500" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);">
            <svg class="w-3 h-3 text-white group-hover:text-[#0A0F1E] transition-colors" viewBox="0 0 12 12" fill="none">
              <path d="M3 6 L9 6 M6 3 L9 6 L6 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      </div>

      <!-- Storitve -->
      <div class="md:col-span-3">
        <div class="mono text-[10px] tracking-[0.22em] uppercase text-white/40 mb-5">Storitve</div>
        <ul class="space-y-2.5 text-[14px]">
          {storitveLinks.map(l => (
            <li><a href={l.href} class="ftr-link">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Podjetje -->
      <div class="md:col-span-2">
        <div class="mono text-[10px] tracking-[0.22em] uppercase text-white/40 mb-5">Podjetje</div>
        <ul class="space-y-2.5 text-[14px]">
          {podjetjeLinks.map(l => (
            <li><a href={l.href} class="ftr-link">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Stik -->
      <div class="md:col-span-2">
        <div class="mono text-[10px] tracking-[0.22em] uppercase text-white/40 mb-5">Stik</div>
        <ul class="space-y-2.5 text-[14px]">
          <li class="text-white/65">
            Kosovelova 16<br/>
            <span class="text-white/45">3000 Celje</span>
          </li>
          <li><a href="tel:+38634901190" class="ftr-link">03 490 11 90</a></li>
          <li><a href="mailto:servis@epromar.si" class="ftr-link">servis@epromar.si</a></li>
          <li class="text-white/55 text-[13px] pt-1">Pon–Pet · 8–16h</li>
        </ul>
      </div>

    </div>

    <!-- Massive wordmark -->
    <div class="relative -mb-4 lg:-mb-12 overflow-hidden">
      <div class="wordmark whitespace-nowrap">epromar.</div>
    </div>

    <!-- Bottom thin meta -->
    <div class="relative z-10 border-t border-white/[0.07] pt-7 mt-10">
      <div class="flex flex-col-reverse md:flex-row items-start md:items-center justify-between gap-4">

        <div class="mono text-[11px] tracking-[0.18em] uppercase text-white/40 flex items-center gap-3 flex-wrap">
          <span>© {leto} Epromar d.o.o.</span>
          <span class="text-white/15">·</span>
          <span>Vse pravice pridržane</span>
        </div>

        <div class="flex items-center gap-5 text-[13px]">
          <a href="#" class="ftr-link text-white/55">Politika zasebnosti</a>
          <span class="text-white/15">·</span>
          <a href="#" class="ftr-link text-white/55">Splošni pogoji</a>
        </div>

      </div>

      <div class="mt-5 flex items-center gap-2 mono text-[10px] tracking-[0.2em] uppercase text-white/30">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 pulse-em"></span>
        <span>Spletna stran v izdelavi — april 2026</span>
      </div>

    </div>
  </div>

</footer>
